{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2023"],
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": ["src", "__tests__", "vite.config.ts", "vite.umd.config.ts", "vitest.config.ts"]
}
